@ long long mul32(long r1, long r0)
@
@ Multiply r1 and r0 and return the product in r1:r0
@
    .thumb_func
        .global mul32
mul32:

    push    {r4, lr}

    uxth    r2, r1
    lsrs    r3, r0, #16
    lsrs    r1, r1, #16
    mov     r4, r1
    muls    r1, r3

    uxth    r0, r0
    muls    r3, r2
    muls    r4, r0
    muls    r0, r2

    movs    r2, #0
    adds    r3, r4
    adcs    r2, r2
    lsls    r2, #16
    adds    r1, r2

    lsls    r2, r3, #16
    lsrs    r3, #16
    adds    r0, r2
    adcs    r1, r3
    pop {r4, pc}

